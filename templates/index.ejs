<%- include('partials/_header') %>

<div class="bg-vibrant"></div>

<div class="container py-5">

    <header class="text-center hero-gradient mb-5 position-relative overflow-hidden shadow-sm">
    <div class="hero-mesh-bg">
        <div class="mesh-ball ball-1"></div>
        <div class="mesh-ball ball-2"></div>
    </div>
    
    <div class="position-relative py-4" style="z-index: 2;">
        <h1 class="display-4 fw-bold mb-2 hero-title">Musique.</h1>
        <p class="fs-6 mb-3 hero-subtitle">Vivez le Rap en haute définition.</p>
        
        <div class="mt-3 d-flex justify-content-center gap-2 flex-wrap">
            <a href="/objects" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm">
                Explorer
            </a>
            <button class="btn btn-backdrop rounded-pill px-4 fw-bold" onclick="playRandom()">
                Aléatoire
            </button>
        </div>
    </div>
</header>

    <div class="mb-5">
        <h3 class="fw-bold mb-4">Parcourir par Mood</h3>
        <div class="row g-3">
            <div class="col-md-3 col-6">
                <a href="/objects?search=Lofi+Rap" class="mood-card" style="--color: #8e44ad;">
                    <i class="bi bi-moon-stars"></i> <span>Détente</span>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a href="/objects?search=Drill+Fr" class="mood-card" style="--color: #c0392b;">
                    <i class="bi bi-lightning-charge"></i> <span>Énergie</span>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a href="/objects?search=Rap+Classique" class="mood-card" style="--color: #2c3e50;">
                    <i class="bi bi-vinyl"></i> <span>Classiques</span>
                </a>
            </div>
            <div class="col-md-3 col-6">
                <a href="/objects?search=Trap" class="mood-card" style="--color: #27ae60;">
                    <i class="bi bi-fire"></i> <span>Tendances</span>
                </a>
            </div>
        </div>
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4 px-2">
        <h2 class="fw-bold m-0 text-white">À l'affiche ce soir</h2>
        <a href="/objects?search=Rap" class="text-danger text-decoration-none fw-bold small">Voir tout ></a>
    </div>

    <div class="row g-4">
<% 
const selections = [
    {
        titre: 'Pyramide', 
        artiste: 'Werenoi', 
        img: 'https://i.scdn.co/image/ab67616d0000b27315a77fc58cab8c163a1b7509',
        preview: 'https://audio-ssl.itunes.apple.com/itunes-assets/AudioVideo116/v4/91/3d/82/913d8282-5360-1634-9721-66795c6f376a/mzaf_15079815967073286047.plus.aac.p.m4a'
    },
    {
        titre: 'A la vie à la mort', 
        artiste: 'SDM', 
        img: 'https://cdn-images.dzcdn.net/images/cover/640220bd3d80561118391eef3a24fb53/0x1900-000000-80-0-0.jpg',
        preview: 'https://audio-ssl.itunes.apple.com/itunes-assets/AudioVideo126/v4/9c/64/9d/9c649d8c-57c2-8409-5f21-872f23607062/mzaf_15003185340628373801.plus.aac.p.m4a'
    },
    {
        titre: 'Saison 00', 
        artiste: 'Gazo', 
        img: 'https://m.media-amazon.com/images/I/A1WjvyC06jL._UF894,1000_QL80_.jpg',
        preview: 'https://audio-ssl.itunes.apple.com/itunes-assets/AudioVideo122/v4/36/57/02/36570259-201b-c198-962a-8956966f3680/mzaf_10928731362723049019.plus.aac.p.m4a'
    }
]; 
%>

        <% selections.forEach(function(item) { %>
            <div class="col-md-4">
<div class="apple-card" onclick="playSong('<%= item.titre %>', '<%= item.artiste %>', '<%= item.img %>', 'URL_DE_TON_MP3_ICI')">                    <div class="img-container mb-3 position-relative">
                        <img src="<%= item.img %>" class="img-fluid rounded-4 shadow-lg w-100" style="aspect-ratio: 1/1; object-fit: cover;">
                        <div class="play-overlay"><i class="bi bi-play-circle-fill"></i></div>
                    </div>
                    <h4 class="fw-bold text-white mb-0"><%= item.titre %></h4>
                    <p class="text-secondary small fw-bold text-uppercase"><%= item.artiste %></p>
                </div>
            </div>
        <% }); %>
    </div>
</div>

<div class="player-bar shadow-lg">
    <div class="container d-flex align-items-center justify-content-between h-100">
        <div class="d-flex align-items-center gap-3 overflow-hidden">
            <img src="<%= selections[0].img %>" id="player-img" class="rounded" style="width: 45px; height: 45px;">
            <div class="text-truncate">
                <div class="text-white fw-bold small mb-0" id="player-title"><%= selections[0].titre %></div>
                <div class="text-muted" style="font-size: 0.7rem;" id="player-artist"><%= selections[0].artiste %></div>
            </div>
        </div>
        <div class="d-flex align-items-center gap-3 fs-3 text-white">
            <i class="bi bi-skip-start-fill"></i>
            <i class="bi bi-play-fill text-danger"></i>
            <i class="bi bi-skip-end-fill"></i>
        </div>
    </div>
</div>

<audio id="main-audio" src=""></audio>

<div class="player-bar shadow-lg">
    <div class="container d-flex align-items-center justify-content-between h-100 px-3">
        <div class="d-flex align-items-center gap-2 gap-md-3 overflow-hidden" style="max-width: 60%;">
            <img src="<%= selections[0].img %>" id="player-img" class="rounded" style="width: 40px; height: 40px; transition: transform 0.5s;">
            <div class="text-truncate">
                <div class="text-white fw-bold mb-0" id="player-title" style="font-size: 0.85rem;"><%= selections[0].titre %></div>
                <div class="text-muted d-none d-sm-block" id="player-artist" style="font-size: 0.7rem;"><%= selections[0].artiste %></div>
            </div>
        </div>
        <div class="d-flex align-items-center gap-3 fs-4 text-white">
            <i class="bi bi-skip-start-fill" style="cursor: pointer;"></i>
            <i class="bi bi-play-fill text-danger" id="play-pause-btn" style="cursor: pointer; font-size: 2.5rem;"></i>
            <i class="bi bi-skip-end-fill d-none d-sm-block" style="cursor: pointer;"></i>
        </div>
    </div>
</div>

<%- include('partials/_footer') %>